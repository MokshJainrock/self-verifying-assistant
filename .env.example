# Copy to ".env" and fill in. The whole app reads config from here.

# --- LLM backend (the Responder) — OpenAI gpt-4o-mini ---
# Put your OpenAI API key in LLM_API_KEY below (get one at platform.openai.com).
# The wrapper is OpenAI-compatible, so to use a local Ollama server instead you'd only
# change the base URL to http://localhost:11434/v1 and the model — no code change.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- Verifier backend (Claude) ---
# The Verifier is a SEPARATE model from the Responder, on purpose (independence).
# Get a key at console.anthropic.com. The SDK reads ANTHROPIC_API_KEY automatically.
ANTHROPIC_API_KEY=sk-ant-...
# Default judge is the strongest model. To cut cost, you MAY set this to
# claude-haiku-4-5 (cheaper/faster) — that's a deliberate cost/accuracy tradeoff.
VERIFIER_MODEL=claude-opus-4-8
